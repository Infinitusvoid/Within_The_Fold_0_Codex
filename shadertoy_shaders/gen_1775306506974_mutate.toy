vec2 wave(vec2 uv)
{
    return uv + vec2(sin(uv.x * 5.0 + iTime * 0.5), sin(uv.y * 3.0 + iTime * 0.3));
}

void mainImage( out vec4 fragColor, in vec2 fragCoord )
{
    vec2 uv = fragCoord/iResolution.xy;
    
    float angle = sin(iTime * 0.5) + uv.x * uv.y;
    mat2 rotationMatrix = mat2(cos(angle), -sin(angle), sin(angle), cos(angle));
    uv *= rotationMatrix;
    
    uv = wave(uv);
    
    vec3 col = 0.5 + 0.5*cos(iTime * 0.3 + uv.xyx * 2.0 + vec3(0,2,4));
    
    float freq = uv.x * 2.0 + sin(iTime * 0.5);
    float offset = sin(freq * 10.0) * 0.05;
    float v = smoothstep(0.4, 0.6, uv.y - offset);
    
    col.r = v;
    col.g = sin(uv.x * 10.0 + (iTime + 0.1 * sin(uv.y * 42.42 + iTime)*sin(uv.y * 100.0 + iTime)));
    col.r = sin(col.g + iTime + 0.42 * sin(iTime * 0.2 + uv.x * 10.0));
    col.b = 0.4 + 0.32 * abs(sin(abs(sin((col.g * col.r) * 32.0)) / sin((sin(col.g) / sin(col.r)) * sin(uv.x * iTime * cos(uv.y * iTime * 1.24)) * 10.0)));
    
    fragColor = vec4(col,1.0);
}