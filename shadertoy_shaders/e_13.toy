mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }
float map(vec3 p)
{
    p.z = mod(p.z,1.2)-0.6;
    p.xy *= rot(0.8*p.z + iTime*0.8);
    vec3 q = abs(p)-vec3(0.33,0.33,0.08);
    return length(max(q,0.0)) + min(max(q.x,max(q.y,q.z)),0.0);
}
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.4,0.7)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    vec3 ro = vec3(0,0,iTime*2.5), rd = normalize(vec3(uv,1.2));
    float t = 0.0, d = 0.0, glow = 0.0;
    for(int i=0;i<80;i++){ vec3 p = ro + rd*t; d = map(p); glow += 0.02/(0.03+abs(d)); if(d<0.001||t>10.0) break; t += d*0.8; }
    vec3 col = pal(0.1*iTime + t*0.05) * glow * 0.15;
    col *= 1.0/(1.0+0.08*t*t);
    fragColor = vec4(col,1.0);
}