mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }

float field(vec3 p)
{
    p.xy *= rot(0.5*iTime);
    p.xz *= rot(0.3*iTime);
    return abs(sin(p.x*2.0)*cos(p.y*2.0) + sin(p.z*2.0)*cos(p.x*2.0) + sin(p.y*2.0)*cos(p.z*2.0)) - 0.25;
}

vec3 norm(vec3 p)
{
    vec2 e = vec2(0.001,0.0);
    return normalize(vec3(
        field(p)-field(p-e.xyy),
        field(p)-field(p-e.yxy),
        field(p)-field(p-e.yyx)
    ));
}

vec3 pal(float t)
{
    return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.28,0.62)+t));
}

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy)/iResolution.y;
    vec3 ro = vec3(0.0,0.0,-3.5);
    vec3 rd = normalize(vec3(uv,1.6));

    float t = 0.0, d = 0.0, glow = 0.0;
    for(int i=0;i<100;i++)
    {
        vec3 p = ro + rd*t;
        d = field(p);
        glow += 0.02/(0.04+abs(d));
        if(d<0.001 || t>8.0) break;
        t += d*0.7;
    }

    vec3 col = vec3(0.01,0.015,0.025);

    if(t<8.0)
    {
        vec3 p = ro + rd*t;
        vec3 n = norm(p);
        vec3 l = normalize(vec3(0.7,0.8,-0.6));
        float dif = max(dot(n,l),0.0);
        float fre = pow(1.0-max(dot(n,-rd),0.0),2.8);
        col = pal(0.1*iTime + 0.3*p.z + 0.2*dif)*(0.25 + dif);
        col += fre*0.5*pal(0.4 + 0.08*iTime);
    }

    col += glow*0.08*pal(0.05*t + 0.1*iTime);
    fragColor = vec4(col,1.0);
}