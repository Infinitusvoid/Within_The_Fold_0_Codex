mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }
float map(vec3 p)
{
    p.xz *= rot(0.8*p.y + iTime);
    p.xz = mod(p.xz,1.2)-0.6;
    return length(p.xz)-0.12;
}
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.32,0.62)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    vec3 ro = vec3(0,0,-2.0), rd = normalize(vec3(uv,1.4));
    float t = 0.0, d = 0.0, glow = 0.0;
    for(int i=0;i<80;i++){ vec3 p=ro+rd*t; d=map(p); glow += 0.02/(0.03+abs(d)); if(d<0.001||t>8.0) break; t+=d*0.8; }
    vec3 col = pal(0.1*iTime + 0.06*t) * glow * 0.18;
    col *= 1.0/(1.0+0.1*t*t);
    fragColor = vec4(col,1.0);
}