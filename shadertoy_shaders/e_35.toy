mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }

float sdCapsule(vec3 p, vec3 a, vec3 b, float r)
{
    vec3 pa = p-a, ba = b-a;
    float h = clamp(dot(pa,ba)/dot(ba,ba),0.0,1.0);
    return length(pa - ba*h)-r;
}

float map(vec3 p)
{
    p.xz *= rot(0.6*iTime);
    p.z += iTime*1.4;
    p.z = mod(p.z,1.0)-0.5;
    return sdCapsule(p, vec3(-0.35,0.0,0.0), vec3(0.35,0.0,0.0), 0.13);
}

vec3 pal(float t)
{
    return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.27,0.58)+t));
}

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy)/iResolution.y;
    vec3 ro = vec3(0.0,0.0,-2.2);
    vec3 rd = normalize(vec3(uv,1.4));

    float t = 0.0, d = 0.0, glow = 0.0;
    for(int i=0;i<90;i++)
    {
        vec3 p = ro + rd*t;
        d = map(p);
        glow += 0.018/(0.03+abs(d));
        if(d<0.001 || t>8.0) break;
        t += d*0.82;
    }

    vec3 col = pal(0.08*iTime + 0.05*t)*glow*0.16;
    col += 0.02/(0.12+dot(uv,uv));
    fragColor = vec4(col,1.0);
}