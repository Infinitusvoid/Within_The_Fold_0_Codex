float hash21(vec2 p){ return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453); }
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.08,0.4,0.72)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    vec2 p = uv*4.0, id = floor(p), gv = fract(p)-0.5;
    vec2 o = 0.25*vec2(sin(iTime + id.x*1.7), cos(1.3*iTime + id.y*1.9));
    float d = length(gv-o);
    float fill = smoothstep(0.32,0.0,d);
    float rim = 0.02/(abs(d-0.28)+0.02);
    vec3 col = pal(0.07*iTime + hash21(id)) * (fill + 0.5*rim);
    fragColor = vec4(col,1.0);
}