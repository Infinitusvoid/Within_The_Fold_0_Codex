float sdBox(vec2 p, vec2 b){ vec2 d=abs(p)-b; return length(max(d,0.0))+min(max(d.x,d.y),0.0); }
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.32,0.64)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 p = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    p *= mat2(cos(0.3*iTime),-sin(0.3*iTime),sin(0.3*iTime),cos(0.3*iTime));
    float d = sdBox(p, vec2(0.25 + 0.08*sin(iTime), 0.25 + 0.08*cos(1.3*iTime)));
    float fill = smoothstep(0.02,0.0,d);
    float glow = 0.03/(abs(d)+0.03);
    vec3 col = pal(0.1*iTime + 2.0*d) * (0.2 + fill + 0.6*glow);
    fragColor = vec4(col,1.0);
}