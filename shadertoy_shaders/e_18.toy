mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.33,0.65)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 p = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    p *= rot(0.35*iTime);
    float a = sin(24.0*p.x + 3.0*sin(2.0*p.y + iTime));
    float b = sin(24.0*(p*rot(1.1)).y - 2.5*cos(2.0*p.x - 1.3*iTime));
    float m = 0.5 + 0.5*a*b;
    vec3 col = pal(0.2*a + 0.2*b + 0.1*iTime) * (0.2 + 1.4*m);
    fragColor = vec4(col,1.0);
}