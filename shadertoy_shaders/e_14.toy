vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.08,0.36,0.66)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    float md = 10.0;
    for(int i=0;i<6;i++){
        float f = float(i);
        vec2 c = 0.42*vec2(cos(iTime + f*1.047), sin(1.4*iTime + f*1.047));
        md = min(md, length(uv-c));
    }
    float line = smoothstep(0.08,0.0,md);
    float glow = 0.025/(md+0.025);
    vec3 col = pal(0.2*iTime + 2.0*md) * (line + 0.5*glow);
    fragColor = vec4(col,1.0);
}