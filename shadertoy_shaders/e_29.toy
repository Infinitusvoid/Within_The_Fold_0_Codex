float smin(float a,float b,float k)
{
    float h = clamp(0.5 + 0.5*(b-a)/k, 0.0, 1.0);
    return mix(b,a,h) - k*h*(1.0-h);
}

float map(vec2 p)
{
    float d = 10.0;
    for(int i=0;i<4;i++)
    {
        float f = float(i);
        float t = iTime + f*1.7;
        vec2 c = 0.36*vec2(cos(1.1*t+f), sin(1.5*t-f));
        float di = length(p-c)-0.22;
        d = (i==0) ? di : smin(d,di,0.24);
    }
    return d;
}

vec3 pal(float t)
{
    return 0.55 + 0.45*cos(6.28318*(vec3(0.03,0.36,0.7)+t));
}

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy)/iResolution.y;

    float d = map(uv);
    float fill = smoothstep(0.03,0.0,d);
    float rim  = smoothstep(0.08,0.0,abs(d));
    float glow = 0.03/(0.03+abs(d));

    vec3 col = pal(0.12*iTime - 1.4*d);
    col *= 0.2 + fill + 0.6*rim;
    col += 0.5*glow*pal(0.25 + 0.1*iTime);
    col += 0.015/(0.2+dot(uv,uv));

    fragColor = vec4(col,1.0);
}