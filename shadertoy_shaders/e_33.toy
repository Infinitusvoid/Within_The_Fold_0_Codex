mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }

vec3 pal(float t)
{
    return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.3,0.7)+t));
}

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 p = (fragCoord - 0.5*iResolution.xy)/iResolution.y;
    p *= rot(0.2*iTime);

    float acc = 0.0;
    vec2 q = p;

    for(int i=0;i<7;i++)
    {
        q = abs(q) - 0.23;
        q *= rot(0.55 + 0.08*iTime);
        float d = abs(length(q)-0.14);
        acc += 0.02/(0.02+d);
    }

    float vign = 1.0/(1.0+1.8*dot(p,p));
    vec3 col = pal(0.1*iTime + 0.3*length(q))*acc*0.18*vign;
    col += 0.03/(0.15+dot(p,p))*pal(0.08*iTime + length(p));

    fragColor = vec4(col,1.0);
}