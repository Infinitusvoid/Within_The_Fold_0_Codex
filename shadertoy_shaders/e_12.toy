float map(vec3 p)
{
    vec3 a = vec3(0.7*sin(iTime), 0.3*cos(1.4*iTime), 3.0);
    vec3 b = vec3(0.8*cos(0.8*iTime+1.5), 0.4*sin(1.2*iTime), 3.6);
    return min(length(p-a)-0.45, length(p-b)-0.32);
}
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.28,0.6)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    vec3 ro = vec3(0,0,0), rd = normalize(vec3(uv,1.5));
    float t = 0.0, d = 0.0;
    for(int i=0;i<72;i++){ vec3 p = ro + rd*t; d = map(p); if(d<0.001||t>8.0) break; t += d*0.7; }
    vec3 col = vec3(0);
    if(t<8.0){
        vec3 p = ro + rd*t; vec2 e = vec2(0.002,0);
        vec3 n = normalize(vec3(map(p)-map(p-e.xyy), map(p)-map(p-e.yxy), map(p)-map(p-e.yyx)));
        float dif = max(dot(n,normalize(vec3(0.5,0.7,-0.6))),0.0);
        col = pal(0.1*iTime + dif) * (0.25 + dif);
        col += 0.03/(abs(d)+0.03);
    }
    col += pal(0.15*iTime + length(uv))*0.02/(length(uv)+0.2);
    fragColor = vec4(col,1.0);
}