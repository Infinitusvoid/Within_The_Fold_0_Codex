mat2 rot(float a){ float c=cos(a), s=sin(a); return mat2(c,-s,s,c); }

float map(vec3 p)
{
    p.xz *= rot(0.7*iTime);
    p.xy *= rot(0.3*iTime);
    vec2 q = vec2(length(p.xz)-0.75, p.y);
    return length(q)-0.16;
}

vec3 norm(vec3 p)
{
    vec2 e = vec2(0.001,0.0);
    return normalize(vec3(
        map(p)-map(p-e.xyy),
        map(p)-map(p-e.yxy),
        map(p)-map(p-e.yyx)
    ));
}

vec3 pal(float t)
{
    return 0.55 + 0.45*cos(6.28318*(vec3(0.0,0.25,0.6)+t));
}

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy)/iResolution.y;

    vec3 ro = vec3(0.0,0.0,-2.7);
    vec3 rd = normalize(vec3(uv,1.7));

    float t = 0.0, d = 0.0, glow = 0.0;
    for(int i=0;i<96;i++)
    {
        vec3 p = ro + rd*t;
        d = map(p);
        glow += 0.02/(0.03 + abs(d));
        if(d<0.001 || t>8.0) break;
        t += d*0.85;
    }

    vec3 col = vec3(0.01,0.015,0.025);

    if(t<8.0)
    {
        vec3 p = ro + rd*t;
        vec3 n = norm(p);
        vec3 l = normalize(vec3(0.6,0.8,-0.5));
        float dif = max(dot(n,l),0.0);
        float fre = pow(1.0-max(dot(n,-rd),0.0),3.0);
        float spec = pow(max(dot(reflect(-l,n),-rd),0.0),24.0);

        col = pal(0.12*iTime + 0.4*p.y + 0.2*dif);
        col *= 0.2 + dif;
        col += 1.3*spec*vec3(1.0);
        col += 0.5*fre*pal(0.2 + 0.1*iTime);
    }

    col += pal(0.08*iTime + 0.1*t)*glow*0.12;
    fragColor = vec4(col,1.0);
}