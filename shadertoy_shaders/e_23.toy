vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.03,0.35,0.7)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    float r = length(uv), a = atan(uv.y,uv.x);
    float d = abs(r - (0.25 + 0.10*sin(3.0*a + iTime)));
    float ring = smoothstep(0.015,0.0,d);
    float arc = pow(max(0.0,cos(6.0*a - 4.0*iTime)),8.0);
    vec3 col = pal(0.1*iTime + r) * ring * (0.2 + 2.0*arc);
    fragColor = vec4(col,1.0);
}