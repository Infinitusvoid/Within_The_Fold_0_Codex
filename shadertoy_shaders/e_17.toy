float hash21(vec2 p){ return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453); }
float noise(vec2 p){
    vec2 i=floor(p), f=fract(p); f=f*f*(3.0-2.0*f);
    return mix(mix(hash21(i),hash21(i+vec2(1,0)),f.x), mix(hash21(i+vec2(0,1)),hash21(i+vec2(1,1)),f.x), f.y);
}
float fbm(vec2 p){
    float v=0.0,a=0.5;
    for(int i=0;i<4;i++){ v+=a*noise(p); p=p*2.02+1.7; a*=0.5; }
    return v;
}
vec3 pal(float t){ return 0.55 + 0.45*cos(6.28318*(vec3(0.1,0.45,0.75)+t)); }

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = (fragCoord - 0.5*iResolution.xy) / iResolution.y;
    vec2 q = vec2(fbm(uv*2.0 + vec2(0.0,0.4*iTime)), fbm(uv*2.0 + vec2(4.0,-0.3*iTime)));
    vec2 p = uv + 0.45*(q-0.5);
    float n = fbm(p*3.0 + vec2(0.0,iTime));
    float m = smoothstep(0.25,0.85,n);
    vec3 col = mix(vec3(0.02,0.03,0.05), pal(n + 0.1*iTime), m);
    col += 0.06/(0.15 + dot(p,p));
    fragColor = vec4(col,1.0);
}